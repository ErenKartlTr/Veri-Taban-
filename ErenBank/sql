-- 1. ZİNCİRLEME TEMİZLİK: Eğer tablolar varsa siler, 'CASCADE' ile onlara bağlı verileri de temizler.
DROP TABLE IF EXISTS musteriler CASCADE; -- Müşteriler tablosunu siler.
DROP TABLE IF EXISTS users CASCADE;      -- Kullanıcılar tablosunu siler.
DROP TABLE IF EXISTS hesap_turleri CASCADE; -- Hesap türleri tablosunu siler.
DROP TABLE IF EXISTS accounts CASCADE;   -- Hesaplar tablosunu siler.
DROP TABLE IF EXISTS transactions CASCADE; -- İşlemler (transfer vb.) tablosunu siler.

-- 2. HESAP TÜRLERİ TABLOSU: Bankadaki hesap kategorilerini (Dolar, Altın vb.) tanımlar.
CREATE TABLE hesap_turleri (
    tur_id SERIAL PRIMARY KEY, -- Otomatik artan benzersiz kimlik numarası (1, 2, 3...)
    tur_adi VARCHAR(50) NOT NULL -- Türün ismi (Örn: Dolar Hesabı), boş bırakılamaz.
);

