-- 1. ZİNCİRLEME TEMİZLİK (Bağımlı tablolarla birlikte siler)
-- CASCADE komutu, users'a bağlı olan accounts gibi tabloları da otomatik temizler.
DROP TABLE IF EXISTS musteriler CASCADE;
DROP TABLE IF EXISTS users CASCADE;
DROP TABLE IF EXISTS hesap_turleri CASCADE;
DROP TABLE IF EXISTS accounts CASCADE; -- Hata veren tablo buydu, bunu da listeye ekledik.
DROP TABLE IF EXISTS transactions CASCADE; -- Varsa bunu da temizleyelim.

-- 2. HESAP TÜRLERİ TABLOSU
CREATE TABLE hesap_turleri (
    tur_id SERIAL PRIMARY KEY,
    tur_adi VARCHAR(50) NOT NULL
);

