-- 3. USERS TABLOSU: Sisteme giriş yapacak ana kullanıcı bilgilerini tutar.
CREATE TABLE users (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY, -- Tahmin edilemez, rastgele karmaşık bir ID üretir.
    first_name VARCHAR(50) NOT NULL, -- Kullanıcının adı.
    last_name VARCHAR(50) NOT NULL,  -- Kullanıcının soyadı.
    email VARCHAR(100) UNIQUE NOT NULL, -- E-posta (UNIQUE: Aynı e-posta iki kez kayıt edilemez).
    password TEXT NOT NULL, -- Şifre verisi (Genelde hash'lenmiş halde saklanır).
    created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now()) -- Kayıt anındaki dünya saatini otomatik yazar.
);

-- 4. MÜŞTERİLER TABLOSU: Bankacılık işlemlerini yapacak olan müşteri profillerini tutar.
CREATE TABLE musteriler (
    musteri_id SERIAL PRIMARY KEY, -- Müşterinin sıra numarası.
    ad VARCHAR(50) NOT NULL, -- Müşteri adı.
    soyad VARCHAR(50) NOT NULL, -- Müşteri soyadı.
    tur_id INT REFERENCES hesap_turleri(tur_id), -- YABANCI ANAHTAR: Sadece 'hesap_turleri'nde olan türleri kabul eder.
    kayit_tarihi TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now()) -- Müşterinin sisteme kayıt edildiği tarih.
);

-- 5. GÜVENLİK (RLS): Veritabanı seviyesinde erişim kısıtlamalarını devreye sokar.
ALTER TABLE hesap_turleri ENABLE ROW LEVEL SECURITY; -- Bu tabloya izinsiz erişimi kapatır.
ALTER TABLE users ENABLE ROW LEVEL SECURITY;         -- Bu tabloya izinsiz erişimi kapatır.
ALTER TABLE musteriler ENABLE ROW LEVEL SECURITY;    -- Bu tabloya izinsiz erişimi kapatır.

-- Herkese INSERT izni (Yeni kayıt oluşturabilmek için dışarıdan veri eklemeye izin verir).
CREATE POLICY "Allow public insert on users" ON users FOR INSERT WITH CHECK (true);
CREATE POLICY "Allow public insert on musteriler" ON musteriler FOR INSERT WITH CHECK (true);

-- Herkese SELECT izni (Uygulama üzerinden verileri okuyup listeleyebilmek için izin verir).
CREATE POLICY "Allow public select on hesap_turleri" ON hesap_turleri FOR SELECT USING (true);
CREATE POLICY "Allow public select on users" ON users FOR SELECT USING (true);
CREATE POLICY "Allow public select on musteriler" ON musteriler FOR SELECT USING (true);
